# Firewallops Convex backend — environment variables (committed CHECKLIST, no values).
#
# IMPORTANT: Convex functions read these via `process.env.*` at RUNTIME. Convex does
# NOT load them from this file (or from any .env). Set them in the Convex Dashboard:
#   Dashboard → <your deployment> → Settings → Environment Variables
# Set them SEPARATELY on each deployment (dev + prod) — values do NOT carry over.
#
# This mirrors what packages/client/.env.example does for the client's build-time
# VITE_* vars: it documents WHICH vars the backend needs without committing secrets.

# Clerk issuer / Frontend API URL for the deployment. Read by convex/auth.config.ts
# (providers[].domain). If `getUserIdentity()` returns null on authed calls, check
# this first — the Clerk JWT template named exactly `convex` must also exist.
CLERK_JWT_ISSUER_DOMAIN=

# Svix signing secret for the Clerk webhook (whsec_...). Read by convex/http.ts to
# verify the `POST /clerk-webhook` signature before provisioning a new account.
# Missing/empty → every webhook returns 400 and no account is provisioned.
CLERK_WEBHOOK_SECRET=

# ── NOT set here ──────────────────────────────────────────────────────────────
# packages/convex/.env.local (gitignored) holds CONVEX_DEPLOYMENT / CONVEX_URL /
# CONVEX_SITE_URL — those are AUTO-MANAGED by `npx convex dev`; do not hand-edit.
# CONVEX_DEPLOY_KEY (prod deploys) lives in the deploy environment (root .env.local
# or your CI/Vercel build env), read by the `convex deploy` CLI — not by app code.
