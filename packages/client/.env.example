# Firewallops web client — build-time env (Vite inlines VITE_* at build).
# Copy to .env.local for local dev; set the deploy values in Vercel.

# Clerk publishable key (pk_...). Clerk Dashboard → API keys → Publishable key.
# The shell gates every route on a Clerk session and cannot boot without it.
VITE_CLERK_PUBLISHABLE_KEY=

# Convex deployment URL (Phase 9 — the pure-Convex authority backend).
# Convex Dashboard → Settings → URL & Deploy Key (the https://<name>.convex.cloud
# deployment URL). The client subscribes to the authority via this URL; a production
# build with this missing/empty throws loudly (no silent fallback). Requires the
# Clerk 'convex' JWT template to exist for authed calls (GATE-AUTH).
VITE_CONVEX_URL=

# ── Colyseus (LEGACY — coexists until the plan-12 cutover, then removed) ──────────
# The wss:// game-server URL (Colyseus). Set in Vercel at deploy time.
VITE_SERVER_URL=
# The https:// Meta-API base for /internal/profile (DISTINCT from VITE_SERVER_URL).
VITE_SERVER_HTTP_URL=
# Opt into the real networked match (1 = networked; unset/0 = hotseat dev loop).
VITE_NETWORKED=
