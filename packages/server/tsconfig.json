{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    // REQUIRED for @colyseus/schema 4.x legacy @type() decorators: with the
    // ES2022 default `useDefineForClassFields: true`, a field initializer like
    // `mobiles = new MapSchema<Mobile>()` is emitted as Object.defineProperty,
    // which BYPASSES the decorator's setter — so the map's child type ($childType)
    // is never set and the schema encoder throws at full-state send
    // ("Cannot read properties of undefined (reading 'Symbol(Symbol.metadata)')").
    // Setting this false restores assignment-through-setter so schema sync works.
    "useDefineForClassFields": false,
    "lib": ["ES2022"],
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "test/**/*.ts"]
}
